# ── Project ──────────────────────────────────────────────────────────
PROJECT_NAME=MeetSync
ENVIRONMENT=development
DEBUG=true

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=meetsync
POSTGRES_USER=meetsync
POSTGRES_PASSWORD=change_me

# ── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── RabbitMQ ─────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=meetsync
RABBITMQ_PASSWORD=change_me

# ── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Service Ports ────────────────────────────────────────────────────
GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
GROUP_SERVICE_PORT=8003
CALENDAR_SERVICE_PORT=8004
IDEAS_SERVICE_PORT=8005
VOTING_SERVICE_PORT=8006
RECOMMENDATION_SERVICE_PORT=8007
NOTIFICATION_SERVICE_PORT=8008
TELEGRAM_SERVICE_PORT=8009
SCHEDULER_SERVICE_PORT=8010

# ── Service URLs (internal Docker network) ───────────────────────────
AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
GROUP_SERVICE_URL=http://group-service:8003
CALENDAR_SERVICE_URL=http://calendar-service:8004
IDEAS_SERVICE_URL=http://ideas-service:8005
VOTING_SERVICE_URL=http://voting-service:8006
RECOMMENDATION_SERVICE_URL=http://recommendation-service:8007
NOTIFICATION_SERVICE_URL=http://notification-service:8008
TELEGRAM_SERVICE_URL=http://telegram-service:8009
SCHEDULER_SERVICE_URL=http://scheduler-service:8010

# ── Telegram Bot ─────────────────────────────────────────────────────
# Leave empty to disable Telegram integration (the service will not start).
# For local dev, leave TELEGRAM_WEBHOOK_URL empty to use long-polling.
# For production, set both and use an HTTPS webhook URL.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/telegram/webhook

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In production, include your domain's HTTPS URL.
CORS_ORIGINS=https://localhost,http://localhost:5173,http://localhost:3000

# ── External APIs ────────────────────────────────────────────────────
# All optional — leave empty to disable the corresponding recommendation source.
TICKETMASTER_API_KEY=
GOOGLE_PLACES_API_KEY=
OPENTRIPMAP_API_KEY=
OPENWEATHER_API_KEY=

# ── Prometheus / Grafana ─────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ── Image Upload ─────────────────────────────────────────────────────
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=/uploads
